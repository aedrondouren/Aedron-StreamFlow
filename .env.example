# Supabase (local or hosted)
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
PRIVATE_SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxx

# Twitch OAuth (for Supabase auth + platform API)
PUBLIC_TWITCH_CLIENT_ID=
PRIVATE_TWITCH_CLIENT_SECRET=

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Kick OAuth (optional)
PUBLIC_KICK_CLIENT_ID=
PRIVATE_KICK_CLIENT_SECRET=
