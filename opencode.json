{
	"$schema": "https://opencode.ai/config.json",
	"permission": "ask",
	"agent": {
		"plan": {
			"permission": {
				"edit": "deny",
				"write": "deny",
				"bash": "allow",
				"glob": "allow",
				"grep": "allow",
				"read": "allow"
			}
		},
		"build": {
			"permission": {
				"edit": "allow",
				"write": "allow",
				"bash": "allow",
				"glob": "allow",
				"grep": "allow",
				"read": "allow"
			}
		}
	},
	"model": "opencode-go/kimi-k2.5",
	"instructions": [".opencode/INSTRUCTIONS.md", "CONTRIBUTING.md"],
	"plugin": ["@sveltejs/opencode"]
}
