{
	"name": "aedron-streamflow",
	"version": "0.0.2",
	"description": "Unified Streaming and Social platform manager for content creators",
	"author": "Aedron <aedronvt@gmail.com>",
	"license": "MIT",
	"private": true,
	"repository": {
		"type": "git",
		"url": "https://github.com/aedrondouren/Aedron-StreamFlow.git"
	},
	"bugs": {
		"url": "https://github.com/aedrondouren/Aedron-StreamFlow/issues"
	},
	"homepage": "https://github.com/aedrondouren/Aedron-StreamFlow#readme",
	"keywords": [
		"streaming",
		"stream",
		"twitch",
		"youtube",
		"kick",
		"sveltekit",
		"supabase",
		"content-creator",
		"live-streaming",
		"unified-chat",
		"obs-overlay"
	],
	"engines": {
		"node": ">=20.0.0"
	},
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"db:generate": "supabase gen types --linked --lang=typescript > src/lib/supabase/database.types.ts",
		"db:push": "supabase db push --linked",
		"db:reset": "supabase db reset --linked",
		"test:user:setup": "node scripts/setup-test-user.js",
		"test:spoof:twitch": "node scripts/spoof-platform-data.js twitch",
		"test:spoof:youtube": "node scripts/spoof-youtube-connected.js",
		"test:spoof:kick": "node scripts/spoof-platform-data.js kick",
		"test:spoof:managed-basic": "node scripts/spoof-managed-basic.js",
		"test:visual:setup": "pnpm test:user:setup && pnpm test:spoof:twitch"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.1",
		"@eslint/js": "^9.39.2",
		"@kvs/node-localstorage": "^2.2.2",
		"@kvs/types": "^2.2.2",
		"@sveltejs/adapter-node": "^5.5.2",
		"@sveltejs/kit": "^2.50.1",
		"@sveltejs/mcp": "^0.1.22",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.1.18",
		"@types/node": "^24",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.14.0",
		"globals": "^17.1.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"supabase": "^2.89.1",
		"svelte": "^5.48.2",
		"svelte-check": "^4.3.5",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.53.1",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"@supabase/ssr": "^0.10.2",
		"@supabase/supabase-js": "^2.103.0",
		"bits-ui": "^2.17.3"
	}
}
